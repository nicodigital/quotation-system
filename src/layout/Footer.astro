---
import getSlug from '@/js/getSlug';
import Brand from "../components/Brand.astro";
import GoTop from "../components/Gotop.astro";
import formatDate from '../js/formatDate';

const currentPath = Astro.url.pathname;
const currPage = getSlug(currentPath);

const response = await fetch(import.meta.env.API_QUOTES);
const QUOTES = await response.json();
const currQuote = QUOTES.find((quote) => quote.slug == currPage);
const formattedDate = formatDate(currQuote.date);

const { lang = 'es' } = Astro.props;

---
<footer class="container row pt-5 pb-10 xg:py-6 items-end" >

    <div class="col-[1/3]">
        <Brand/>
    </div>

    <div class="col-[1/5] md:col-[3/11] pl-2 md:pl-0">
        <div class="wp-block-columns">

            <div class="wp-block-column mb-0" style="flex-basis:33.33%"> &nbsp; </div>
            
            <div class="wp-block-column mb-0 flex items-end" style="flex-basis:33.33%">

                <p class="text-small mb-0">
                    {lang === 'pt' ? 'Cotação realizada' : 'Cotización realizada'} <br> {lang === 'pt' ? 'em' : 'el'} {formattedDate}
                </p>

            </div>

            <div class="wp-block-column mb-0 flex flex-col text-small" style="flex-basis:33.33%">
                <a class="link-underline" href="mailto:nicolook.pro@gmail.com">nicolook.pro@gmail.com</a>
                <a class="link-underline" href="https://nicolasgonzalez.dev" target='_blank' rel='noreferrer noopener' >nicolasgonzalez.dev</a>
                <p>
                    UY: +598 98 398 010 <br>
                    BR: +55 41 999 39 00 88
                </p>
            </div>

        </div>
    </div>

    <div class="col-[11/13]">
        <GoTop/>
    </div>

</footer>

